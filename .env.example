# Supabase — find værdierne i Supabase Dashboard > Project Settings > API
# Kopiér denne fil til .env.local og udfyld DÉR. Skriv ALDRIG rigtige nøgler
# i denne fil — den er committet til git.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role-nøgle — KUN i .env.local, server-side. Omgår RLS. Commit ALDRIG.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direkte/pooler DB-connection string (Dashboard > "Connect" > Session pooler).
# Nemmeste vej til at pushe migrations:  supabase db push --db-url "$SUPABASE_DB_URL"
SUPABASE_DB_URL=postgresql://postgres.YOUR-REF:[password]@aws-0-<region>.pooler.supabase.com:5432/postgres
